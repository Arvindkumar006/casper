{
  "version": 2,
  "builds": [
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "config/compliance.json",
          "history_db.json",
          "assets_db.json",
          "mock_private_key.pem",
          "mock_public_key.pem"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/history",
      "dest": "/api/history.ts"
    },
    {
      "src": "/api/assets",
      "dest": "/api/assets.ts"
    },
    {
      "src": "/api/run",
      "dest": "/api/run.ts"
    },
    {
      "src": "/api/swarm-state",
      "dest": "/api/swarm-state.ts"
    },
    {
      "src": "/api/execute-mission",
      "dest": "/api/execute-mission.ts"
    },
    {
      "src": "/api/verify",
      "dest": "/api/verify.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
