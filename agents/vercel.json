{
  "version": 2,
  "builds": [
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/history",
      "dest": "/api/history.ts"
    },
    {
      "src": "/api/run",
      "dest": "/api/run.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
